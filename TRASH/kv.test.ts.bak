import { describe, expect, it, vi } from "vitest";
import { effect } from "../../core/effect";
import { kvStore } from "../../memory/kv";

describe("kvStore — Phase 0: Reactive KV Store", () => {
	// -----------------------------------------------------------------------
	// Basic CRUD
	// -----------------------------------------------------------------------
	describe("basic CRUD", () => {
		it("get/set/has/delete", () => {
			const kv = kvStore<number>();
			expect(kv.get("a")).toBe(undefined);
			expect(kv.has("a")).toBe(false);

			kv.set("a", 1);
			expect(kv.get("a")).toBe(1);
			expect(kv.has("a")).toBe(true);

			expect(kv.delete("a")).toBe(true);
			expect(kv.get("a")).toBe(undefined);
			expect(kv.has("a")).toBe(false);
			expect(kv.delete("a")).toBe(false);
			kv.destroy();
		});

		it("keys/size/entries", () => {
			const kv = kvStore<string>();
			kv.set("x", "hello");
			kv.set("y", "world");

			expect(kv.size()).toBe(2);
			expect(kv.keys()).toEqual(["x", "y"]);
			expect(kv.entries()).toEqual([
				["x", "hello"],
				["y", "world"],
			]);
			kv.destroy();
		});

		it("clear removes all keys", () => {
			const kv = kvStore<number>();
			kv.set("a", 1);
			kv.set("b", 2);
			kv.clear();
			expect(kv.size()).toBe(0);
			expect(kv.keys()).toEqual([]);
			kv.destroy();
		});

		it("overwrite existing key", () => {
			const kv = kvStore<number>();
			kv.set("a", 1);
			kv.set("a", 2);
			expect(kv.get("a")).toBe(2);
			expect(kv.size()).toBe(1);
			kv.destroy();
		});
	});

	// -----------------------------------------------------------------------
	// Reactive API
	// -----------------------------------------------------------------------
	describe("reactive API", () => {
		it("store() returns a reactive WritableStore for a key", () => {
			const kv = kvStore<number>();
			const s = kv.store("a");
			expect(s.get()).toBe(undefined);

			kv.set("a", 42);
			expect(s.get()).toBe(42);

			// Writing through the store updates the KV
			s.set(99);
			// Note: writing through store doesn't update _map (store is independent)
			// This is by design — store() is for reactive subscriptions
			kv.destroy();
		});

		it("store() returns same store for same key", () => {
			const kv = kvStore<number>();
			const s1 = kv.store("a");
			const s2 = kv.store("a");
			expect(s1).toBe(s2);
			kv.destroy();
		});

		it("select() returns a read-only derived store", () => {
			const kv = kvStore<number>();
			const s = kv.select("a");
			expect(s.get()).toBe(undefined);

			kv.set("a", 10);
			expect(s.get()).toBe(10);

			kv.delete("a");
			expect(s.get()).toBe(undefined);
			kv.destroy();
		});

		it("keysStore reactively tracks key changes", () => {
			const kv = kvStore<number>();
			const log: string[][] = [];
			const dispose = effect([kv.keysStore], () => {
				log.push([...kv.keysStore.get()]);
			});

			kv.set("a", 1);
			kv.set("b", 2);
			kv.delete("a");

			// Initial + 3 changes
			expect(log).toEqual([[], ["a"], ["a", "b"], ["b"]]);
			dispose();
			kv.destroy();
		});

		it("sizeStore reactively tracks size", () => {
			const kv = kvStore<number>();
			const log: number[] = [];
			const dispose = effect([kv.sizeStore], () => {
				log.push(kv.sizeStore.get());
			});

			kv.set("a", 1);
			kv.set("b", 2);
			kv.delete("a");

			expect(log).toEqual([0, 1, 2, 1]);
			dispose();
			kv.destroy();
		});
	});

	// -----------------------------------------------------------------------
	// Batch
	// -----------------------------------------------------------------------
	describe("batch", () => {
		it("setMany sets multiple keys atomically", () => {
			const kv = kvStore<number>();
			const log: number[] = [];
			const dispose = effect([kv.sizeStore], () => {
				log.push(kv.sizeStore.get());
			});

			kv.setMany({ a: 1, b: 2, c: 3 });
			expect(kv.size()).toBe(3);
			expect(kv.get("a")).toBe(1);
			expect(kv.get("b")).toBe(2);
			expect(kv.get("c")).toBe(3);

			// Should have initial (0) then one batched update (3)
			expect(log).toEqual([0, 3]);
			dispose();
			kv.destroy();
		});

		it("setMany accepts array of tuples", () => {
			const kv = kvStore<string>();
			kv.setMany([
				["x", "hello"],
				["y", "world"],
			]);
			expect(kv.get("x")).toBe("hello");
			expect(kv.get("y")).toBe("world");
			kv.destroy();
		});
	});

	// -----------------------------------------------------------------------
	// TTL
	// -----------------------------------------------------------------------
	describe("TTL", () => {
		it("setWithTTL expires key after timeout", async () => {
			vi.useFakeTimers();
			const kv = kvStore<number>();

			kv.setWithTTL("temp", 42, 100);
			expect(kv.get("temp")).toBe(42);

			vi.advanceTimersByTime(50);
			expect(kv.has("temp")).toBe(true);

			vi.advanceTimersByTime(51);
			expect(kv.has("temp")).toBe(false);
			expect(kv.get("temp")).toBe(undefined);

			kv.destroy();
			vi.useRealTimers();
		});

		it("defaultTTL applies to all keys", () => {
			vi.useFakeTimers();
			const kv = kvStore<number>({ defaultTTL: 200 });

			kv.set("a", 1);
			kv.set("b", 2);

			vi.advanceTimersByTime(201);
			expect(kv.has("a")).toBe(false);
			expect(kv.has("b")).toBe(false);

			kv.destroy();
			vi.useRealTimers();
		});

		it("setWithTTL overrides defaultTTL", () => {
			vi.useFakeTimers();
			const kv = kvStore<number>({ defaultTTL: 100 });

			kv.setWithTTL("a", 1, 500);

			vi.advanceTimersByTime(101);
			expect(kv.has("a")).toBe(true); // Still alive (500ms TTL)

			vi.advanceTimersByTime(400);
			expect(kv.has("a")).toBe(false);

			kv.destroy();
			vi.useRealTimers();
		});

		it("delete clears TTL timer", () => {
			vi.useFakeTimers();
			const kv = kvStore<number>();

			kv.setWithTTL("a", 1, 100);
			kv.delete("a");

			// Re-add without TTL
			kv.set("a", 2);
			vi.advanceTimersByTime(200);

			// Should still be there (no TTL on re-add)
			expect(kv.has("a")).toBe(true);
			kv.destroy();
			vi.useRealTimers();
		});
	});

	// -----------------------------------------------------------------------
	// Lifecycle
	// -----------------------------------------------------------------------
	describe("lifecycle", () => {
		it("destroy prevents further writes", () => {
			const kv = kvStore<number>();
			kv.set("a", 1);
			kv.destroy();
			kv.set("b", 2);
			expect(kv.has("b")).toBe(false);
		});

		it("destroy clears TTL timers", () => {
			vi.useFakeTimers();
			const kv = kvStore<number>();
			kv.setWithTTL("a", 1, 100);
			kv.destroy();
			vi.advanceTimersByTime(200);
			// No errors — timer was cleaned up
			vi.useRealTimers();
		});
	});

	// -----------------------------------------------------------------------
	// Custom equals
	// -----------------------------------------------------------------------
	it("custom equals prevents duplicate emissions", () => {
		const kv = kvStore<{ x: number }>({
			equals: (a, b) => a.x === b.x,
		});

		const s = kv.store("a");
		const log: Array<{ x: number } | undefined> = [];
		const dispose = effect([s], () => {
			log.push(s.get());
		});

		kv.set("a", { x: 1 });
		kv.set("a", { x: 1 }); // Same by custom equals — should be deduped
		kv.set("a", { x: 2 });

		expect(log).toEqual([undefined, { x: 1 }, { x: 2 }]);
		dispose();
		kv.destroy();
	});
});
